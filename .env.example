# --- MySQL (Aiven) ---
# Get these from: aiven.io → your MySQL service → Overview tab
DB_HOST=mysql-xxxxxxxx.aivencloud.com
DB_PORT=3306
DB_USER=avnadmin
DB_PASSWORD=your_aiven_password_here
DB_NAME=defaultdb
DB_SSL=true

# --- PesaPal (already configured — just copy as-is) ---
PESAPAL_CONSUMER_KEY=Z9IMI3a4DPVqtCgRE/2HgJrYiblnOQFR
PESAPAL_CONSUMER_SECRET=zNvAgCOZA+z84uY1p0yTIQmZUQ0=
PESAPAL_ENV=production

# --- Vercel URL (set after first deploy) ---
# Example: moresave-sacco.vercel.app
VERCEL_URL=your-app.vercel.app

# --- Email (optional) ---
EMAIL_SERVICE=gmail
