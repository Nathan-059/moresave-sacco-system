{
  "build": {
    "builder": "NIXPACKS",
    "buildCommand": "cd moresave-react/server && npm install"
  },
  "deploy": {
    "startCommand": "cd moresave-react/server && node index.js",
    "healthcheckPath": "/api/health",
    "restartPolicyType": "ON_FAILURE",
    "restartPolicyMaxRetries": 3
  }
}
