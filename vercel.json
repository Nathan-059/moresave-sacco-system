{
  "version": 2,
  "buildCommand": "cd moresave-react && npm install && npm run build",
  "outputDirectory": "moresave-react/dist",
  "rewrites": [
    { "source": "/api/(.*)", "destination": "https://moresave-sacco-system-production.up.railway.app/api/$1" },
    { "source": "/(.*)", "destination": "/index.html" }
  ]
}
